+class TestMoELoraRegression(unittest.TestCase):
+
+    def test_sglang_moe_parity_strict(self):
+
+        with SRTRunner(
+            model_path=MODEL_PATH,
+            torch_dtype=torch.bfloat16,
+            model_type="generation",
+            lora_paths=[LORA_PATH],
+            lora_backend="triton",

+        self,
+        intermediate_input: torch.Tensor,  # [M * top_k, intermediate_dim]
+        intermediate_cache: torch.Tensor,  # [M, top_k, hidden_dim]
+        topk_weights: torch.Tensor,  # [M, top_k]

+        ),
+        dtype=dtype,
+        device=device,
+    )
+
+    # fused_moe_lora_kernel output
+    output = torch.zeros((num_tokens, top_k_num, N), dtype=dtype, device=device)
+
+    use_fused_moe_lora_kernel(
+        topk_ids,
+        topk_weights,
